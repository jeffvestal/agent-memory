# agent-memory Configuration
# Copy to .env and fill in values, or run ./install.sh for interactive setup

# Elasticsearch Serverless endpoint (from cloud.elastic.co → your deployment)
BRIDGE_ES_URL=https://your-project.es.us-east-1.aws.elastic.cloud

# API key (create in Kibana → Stack Management → API Keys)
BRIDGE_ES_API_KEY=your-api-key-here

# Short name for this agent (e.g. "myagent", "assistant", "coder")
BRIDGE_AGENT_ID=myagent

# Kibana URL (optional — enables Agent Builder and dashboard import)
# KIBANA_URL=https://your-project.kb.us-east-1.aws.elastic.cloud

# Directories to index as searchable entities (space-separated)
# Default: current working directory
# BRIDGE_WATCH_DIRS=/path/to/project/docs /path/to/notes

# Path to Claude Code auto-memory directory for this agent
# Default: ~/.claude/projects/<cwd-as-path>/memory
# BRIDGE_MEMORY_PATH=/path/to/memory/dir

# Index names (auto-set by install.sh — override only if needed)
# BRIDGE_ENTITY_INDEX=myagent-entities
# BRIDGE_ENTITY_HISTORY_INDEX=myagent-entity-history

# Optional: timeout in seconds for ES requests (default: 5)
# BRIDGE_TIMEOUT=5

# Knowledge graph options
# Agent Builder agent ID for bridge graph gen-handoff --synthesize
# BRIDGE_SYNTHESIS_AGENT=my-synthesis-agent
# Alert tags to monitor in bridge graph health (default: ingest-failure)
# BRIDGE_INGEST_ALERT_TAGS=ingest-failure
